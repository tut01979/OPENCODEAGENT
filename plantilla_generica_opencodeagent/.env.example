# ==============================================================================
#                  O P E N C O D E   A G E N T   -   .ENV
#                    (Plantilla Genérica y Reutilizable)
# ==============================================================================
# INSTRUCCIONES:
# 1. Haz una copia de este archivo y renómbralo a '.env'.
# 2. Reemplaza todos los valores que digan "SUSTITUYE_..." con tus verdaderas claves.
# 3. NUNCA subas tu archivo '.env' real a GitHub o a foros públicos.

# ------------------------------------------------------------------------------
# 1. TELEGRAM BOT
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="SUSTITUYE_POR_TU_TOKEN_DE_BOTFATHER"
TELEGRAM_ALLOWED_USER_IDS="SUSTITUYE_POR_TU_USER_ID,OTRO_USER_ID"

# ------------------------------------------------------------------------------
# 2. BASE DE DATOS LOCAL
# ------------------------------------------------------------------------------
DB_PATH="./data/memory.db"

# ------------------------------------------------------------------------------
# 3. FIREBASE (Persistencia Inteligente)
# ------------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"
FIREBASE_PROJECT_ID="SUSTITUYE_POR_TU_PROJECT_ID" # Ejem: opencodeagent-xxxxx

# ------------------------------------------------------------------------------
# 4. INTELIGENCIA ARTIFICIAL MÚLTIPLE (Con Fallbacks)
# ------------------------------------------------------------------------------
# 4.1. GROQ (Modelo Principal Ultrarrápido)
GROQ_API_KEY="SUSTITUYE_POR_TU_GROQ_API_KEY"

# 4.2. OPENROUTER (Para Modelos Avanzados como Gemini)
OPENROUTER_API_KEY="SUSTITUYE_POR_TU_OPENROUTER_API_KEY"
OPENROUTER_MODEL="google/gemini-2.0-flash-001"
OPENROUTER_TEXT_MODEL="openai/gpt-4o-mini"

# 4.3. OLLAMA (Local - Opcional)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# ------------------------------------------------------------------------------
# 5. VOCES Y AUDIO
# ------------------------------------------------------------------------------
# ElevenLabs API y Mapeos
ELEVENLABS_API_KEY="SUSTITUYE_POR_TU_API_ELEVENLABS"

# IDs de voces en ElevenLabs separadas por coma (Orden de prioridad)
ELEVENLABS_VOICE_IDS="SUSTITUYE_POR_VOICE_ID_1,SUSTITUYE_POR_VOICE_ID_2"
# Nombres de las voces que corresponden a los IDs anteriores (para logs)
ELEVENLABS_VOICE_NAMES="Voz Uno, Voz Dos"

# Fallback en caso de que ElevenLabs y Google fallen (TTSMP3 Polly)
# Opciones disponibles en español: Lucia, Enrique, Conchita, Miguel, Penelope
VOICE_FALLBACK_LIST="Lucia,Enrique,Conchita,Miguel,Penelope"

# ------------------------------------------------------------------------------
# 6. TAREAS PROGRAMADAS (Cron Format)
# ------------------------------------------------------------------------------
CRON_SCHEDULE="30 6 * * *"
